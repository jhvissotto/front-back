   "source": [
    "import base64\n",
    "import hashlib"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3eb8e2c7",
   "metadata": {},
   "outputs": [],
   "source": [
    "SALT = '__SALT__'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5ea93044",
   "metadata": {},
   "outputs": [],
   "source": [
    "def hash_generate(pword):\n",
    "    data = (SALT + pword).encode('utf-8')\n",
    "    digest = hashlib.sha256(data).digest()\n",
    "    return base64.b64encode(digest).decode('utf-8')\n",
    "\n",
    "print(hash_generate('12345'))"
   ]
  }
 ],
